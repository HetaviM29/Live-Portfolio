# Copy this file to backend/.env and fill your real values
# Use ONE provider key:
# 1) Groq key starts with gsk_...
# 2) xAI Grok key starts with xai-...

GROQ_API_KEY=YOUR_PROVIDER_KEY

# Optional model overrides
# GROQ_MODEL=llama-3.1-8b-instant
# XAI_MODEL=grok-3-mini

# CORS allowlist (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://live-portfolio-1.onrender.com

# Optional explicit frontend origin (used in addition to ALLOWED_ORIGINS)
# FRONTEND_URL=https://live-portfolio-1.onrender.com
